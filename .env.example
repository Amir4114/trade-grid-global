# Trade Grid Global — environment template
# Copy to .env.local and fill values. Never commit secrets.

# -----------------------------------------------------------------------------
# Required — Next.js app (Supabase)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Optional — verification scripts / trusted server tooling
# Used by scripts/verify-*.mjs. Do NOT expose to the browser.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Reserved placeholders — NOT currently wired in this repository
# App uses Supabase Auth (not NextAuth). AI email/Sentry are Not implemented.
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=
OPENAI_API_KEY=
RESEND_API_KEY=
SENTRY_DSN=
